# API-only image for capacity load testing (skips frontend production build).
FROM node:20-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev
COPY . .
RUN addgroup -g 1001 -S nodejs && adduser -S nodejs -u 1001 -G nodejs \
    && chown -R nodejs:nodejs /app
USER nodejs
ENV NODE_ENV=production
EXPOSE 5000
CMD ["node", "server.js"]
