{
  "name": "lms",
  "version": "1.0.0",
  "description": "Learning Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "predev": "node scripts/freePort.js 5000 --wait",
    "dev": "nodemon",
    "dev:clean": "node scripts/freePort.js 5000 --wait && nodemon",
    "stop:dev": "node scripts/freePort.js 5000 --wait",
    "check:mongo": "node scripts/testMongoConnection.js",
    "worker:quizwave-cleanup": "node workers/quizwaveCleanupWorker.js",
    "worker:grading-jobs": "node workers/gradingJobsWorker.js",
    "obs:up": "docker compose -f monitoring/docker-compose.observability.yml up -d",
    "obs:down": "docker compose -f monitoring/docker-compose.observability.yml down",
    "obs:logs": "docker compose -f monitoring/docker-compose.observability.yml logs -f",
    "smoke:predeploy": "node scripts/predeploySmokeCheck.js",
    "seed:demo:math8-india": "node scripts/seedGrade8MathIndiaDemo.js",
    "seed:demo:math8-india:sync-pages": "node scripts/seedGrade8MathIndiaDemo.js --sync-pages",
    "seed:demo:eng8-india": "node scripts/seedGrade8EnglishIndiaDemo.js",
    "seed:demo:eng8-india:sync-pages": "node scripts/seedGrade8EnglishIndiaDemo.js --sync-pages",
    "patch:demo:math8-realism": "node scripts/patchGrade8Math8DemoRealism.js",
    "audit:duplicates": "node scripts/auditDuplicateExtensions.js",
    "build": "cd frontend && npm install && npm run build",
    "build:frontend": "bash -c 'cd frontend && NODE_ENV= npm install && npm run build'",
    "test": "jest",
    "test:api": "jest tests/unit/api tests/integration --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:grading": "jest tests/grading --runInBand --forceExit",
    "test:grading:policy": "jest tests/grading --testPathPattern=policy|parity",
    "verify:grading": "node scripts/verifySharedGrading.js && node scripts/checkDeprecatedGradingCalculator.js",
    "verify:workflows": "node scripts/validateWorkflowFiles.js",
    "validate:indexes": "node scripts/validateMongoIndexes.js",
    "migrate": "node scripts/migrations/run.js",
    "migrate:dry-run": "node scripts/migrations/run.js --dry-run",
    "verify:audit-integrity": "node scripts/verifyAuditIntegrity.js",
    "verify:snapshots": "node scripts/verifySnapshots.js",
    "perf:gradebook": "node scripts/perf/gradebookBench.js",
    "test:portability": "jest tests/portability --runInBand",
    "test:migration": "jest tests/migration --runInBand --forceExit",
    "verify:institution-export": "node scripts/verifyInstitutionExport.js",
    "export:institution": "node scripts/exportInstitutionBundle.js",
    "restore:institution": "node scripts/restoreInstitutionBundle.js",
    "verify:data-integrity": "node scripts/verifyDataIntegrity.js",
    "verify:restore": "node scripts/verifyRestore.js",
    "verify:backup-compatibility": "node scripts/verifyBackupCompatibility.js",
    "migrate:legacy-files": "node scripts/migrations/registerLegacyUploads.js --apply",
    "migrate:legacy-files:dry-run": "node scripts/migrations/registerLegacyUploads.js --dry-run",
    "verify:file-orphans": "node scripts/verifyFileOrphans.js",
    "cleanup:file-orphans": "node scripts/cleanupFileOrphans.js",
    "cleanup:file-orphans:apply": "node scripts/cleanupFileOrphans.js --apply",
    "verify:file-integrity": "node scripts/verifyFileIntegrity.js",
    "verify:blob-reconciliation": "node scripts/verifyBlobReconciliation.js",
    "test:files": "jest tests/file-access tests/file-versioning tests/ferpa-files --runInBand",
    "test:institutional-workflows": "jest tests/institutional-workflows --runInBand",
    "test:scale": "node scripts/perf/gradebookBench.js",
    "verify:restore-parity": "node scripts/verifyRestoreParity.js",
    "worker:file-maintenance": "node workers/fileMaintenanceWorker.js",
    "test:load": "node scripts/load/institutionalLoadBench.js",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:e2e:install": "playwright install chromium",
    "seed:e2e:upload": "node scripts/seedUploadE2e.js",
    "test:e2e:seeded": "npm run seed:e2e:upload && playwright test -c e2e/playwright.config.ts",
    "verify:production-health": "node scripts/verifyProductionHealth.js",
    "verify:index-integrity": "node scripts/verifyIndexIntegrity.js",
    "verify:file-platform": "node scripts/verifyFilePlatform.js",
    "verify:file-platform:full": "node scripts/verifyFilePlatformFull.js",
    "migrate:syllabus-fileassets": "node scripts/migrations/migrateSyllabusFileAssets.js --apply",
    "migrate:syllabus-fileassets:dry-run": "node scripts/migrations/migrateSyllabusFileAssets.js",
    "verify:syllabus-fileassets": "node scripts/verifySyllabusFileAssets.js",
    "verify:blob-restore": "node scripts/verifyBlobRestore.js",
    "restore:institution:blobs": "node scripts/restoreInstitutionBlobs.js",
    "test:file-scale": "node scripts/load/fileScaleBench.js",
    "test:file-recovery": "jest tests/file-recovery --runInBand",
    "verify:file-platform:institutional": "node scripts/verifyFilePlatformInstitutional.js",
    "verify:upload-platform:final": "node scripts/verifyUploadPlatformFinal.js",
    "verify:upload-recovery": "node scripts/verifyUploadRecovery.js",
    "verify:upload-production-closure": "node scripts/verifyUploadProductionClosure.js",
    "test:e2e:uploads": "playwright test -c e2e/playwright.config.ts e2e/specs/upload-reliability.spec.ts e2e/specs/upload-platform.spec.ts",
    "test:chunk-upload": "jest tests/chunk-upload --runInBand",
    "worker:blob-purge": "node workers/blobPurgeWorker.js",
    "worker:blob-purge:apply": "node workers/blobPurgeWorker.js --apply",
    "test:files:all": "jest tests/file-access tests/file-versioning tests/ferpa-files tests/blob-reconciliation tests/file-cleanup tests/file-integrity tests/storage-portability tests/uploads tests/file-recovery tests/blob-restore tests/blob-retention --runInBand"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@tailwindcss/typography": "^0.5.10",
    "@tinymce/tinymce-react": "^6.2.1",
    "@types/react-beautiful-dnd": "^13.1.8",
    "archiver": "^8.0.0",
    "autoprefixer": "^10.4.18",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.10",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.3",
    "express-rate-limit": "^8.4.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "mongoose": "^8.2.1",
    "multer": "^2.0.0",
    "nodemailer": "^8.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.22.3",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.1.0",
    "supertest": "^7.1.4",
    "typescript": "^5.8.3"
  }
}
