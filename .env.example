# Database
MONGODB_URI=mongodb://username:password@host1:27017,host2:27017,host3:27017/lms?authSource=admin&replicaSet=atlas-xxxx-shard-0&tls=true
MONGO_DB_NAME=lms
MONGO_MAX_POOL_SIZE=80
MONGO_MIN_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=45000

# Server
NODE_ENV=production
PORT=5000
LOG_LEVEL=info

# Auth
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRE=7d
# AUTH_COOKIE_SECURE=true
# Set when FRONTEND_URL is https:// (auto-detected). Use false for local HTTP-only dev.
# METRICS_TOKEN=replace_with_random_token_for_prometheus_scraping
# Protects GET /metrics and GET /health/ops in production
# DISABLE_PUBLIC_REGISTRATION=true
# Comma-separated extra browser origins allowed in production CORS (optional)
# CORS_EXTRA_ORIGINS=https://staging.example.com

# Rate limiting (applied only when NODE_ENV=production, unless you opt in below)
# Defaults in server.js: RATE_LIMIT_MAX=900, WRITE_RATE_LIMIT_MAX=240 (SPA burst friendly).
# In development/test, limits are OFF unless ENFORCE_RATE_LIMIT_IN_DEV=true.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=900
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30
WRITE_RATE_LIMIT_WINDOW_MS=60000
WRITE_RATE_LIMIT_MAX=240
# ENFORCE_RATE_LIMIT_IN_DEV=true
# DISABLE_RATE_LIMIT=true
# GET/HEAD/OPTIONS on /api/inbox, /api/grades, /api/submissions, /api/upload use RATE_LIMIT_* only.
# Mutations (POST/PUT/PATCH/DELETE) still hit WRITE_RATE_LIMIT_* on those path prefixes.

# Inbox / messaging (Phase 0+)
# Production: set MESSAGE_SANITIZER=dompurify for stronger HTML sanitization
MESSAGE_SANITIZER=regex
INBOX_CACHE_VERSION=v2
MESSAGING_POLICY_ENFORCED=false
INBOX_DENORM_UNREAD=true
INBOX_REJECT_LEGACY_ATTACHMENTS=false

# Phase 7 — audit, anti-spam, dedicated rate limits
INBOX_AUDIT_ENABLED=false
INBOX_AUDIT_READ_EVENTS=false
INBOX_ANTISPAM_ENFORCED=false
INBOX_COMPOSE_WINDOW_MS=60000
INBOX_COMPOSE_MAX=12
INBOX_SEND_WINDOW_MS=60000
INBOX_SEND_MAX=45
INBOX_MAX_MESSAGES_PER_MINUTE=30
INBOX_MAX_CONVERSATIONS_PER_HOUR=40
INBOX_DUPLICATE_WINDOW_SEC=90
# ENABLE_NOTIFICATION_TEST_CREATE=true
NOTIFICATION_DEDUPE_ENABLED=true
# NOTIFICATION_RETENTION_ENABLED=false
NOTIFICATION_WEBSOCKET_ENABLED=true
# Frontend build (Vercel / frontend/.env): VITE_NOTIFICATION_WEBSOCKET_ENABLED=true
# Frontend build: VITE_NOTIFICATION_POLL_MS=30000
# DOMAIN_EVENTS_ENABLED=false
# PLANNER_UX_ENABLED=false  # set true on API server for capacity load tests (npm run test:load:capacity)
# PLANNER_FEED_CAP=50
# PLANNER_SNOOZE_DEFAULT_HOURS=24
# Frontend: VITE_PLANNER_UX_ENABLED=true
# ACADEMIC_NOTIFICATION_EXPANSION_ENABLED=false
# ACADEMIC_NOTIFICATION_FANOUT_CONCURRENCY=10
# PLANNER_MISSING_ASSIGNMENTS_ENABLED=false
# PLANNER_MISSING_LOOKBACK_DAYS=90

# Phase 8 — Socket.IO /messaging namespace (requires Redis adapter for multi-node)
INBOX_WEBSOCKET_ENABLED=true
# Frontend build: VITE_INBOX_WEBSOCKET_ENABLED=true
# MESSAGING_THROTTLE_WINDOW_MS=1000
# MESSAGING_THROTTLE_SUBSCRIBE_MAX=30

# Index and startup behavior
SYNC_INDEXES_ON_BOOT=true

# Redis (required for multi-instance socket/pubsub and recommended for scale)
REDIS_URL=redis://localhost:6379
REQUIRE_REDIS=true
REQUIRE_JOB_QUEUE=true
REQUIRE_MULTI_INSTANCE=false
APP_HEALTH_URLS=https://app-node-1.example.com,https://app-node-2.example.com,https://app-node-3.example.com

# P2 — BullMQ workers (require REDIS_URL; inline fallback when Redis unavailable)
NOTIFICATION_FANOUT_QUEUE_ENABLED=true
NOTIFICATION_FANOUT_WORKER_CONCURRENCY=2
FILE_SCAN_QUEUE_ENABLED=true
FILE_SCAN_WORKER_CONCURRENCY=3
QUIZWAVE_DISTRIBUTED_TIMERS=true
GRADES_AVERAGE_BATCH_MAX=25
NIGHTLY_INBOX_REPAIR_LIMIT=5000
NIGHTLY_NOTIFICATION_RECONCILE_LIMIT=500

# Socket.IO engine (timeouts / payload cap)
SOCKET_CONNECT_TIMEOUT_MS=45000
SOCKET_PING_TIMEOUT_MS=20000
SOCKET_PING_INTERVAL_MS=25000
SOCKET_MAX_HTTP_BUFFER_BYTES=1048576

# QuizWave per-socket throttling (sliding window per event name, milliseconds)
QUIZWAVE_THROTTLE_WINDOW_MS=1000
QUIZWAVE_THROTTLE_JOIN_MAX=6
QUIZWAVE_THROTTLE_ANSWER_MAX=10
QUIZWAVE_THROTTLE_TEACHER_ACTION_MAX=20
QUIZWAVE_THROTTLE_LEADERBOARD_MAX=24
QUIZWAVE_THROTTLE_DEFAULT_MAX=40

# Day 4 socket validation (optional strict gate for CI)
DAY4_REQUIRE_REDIS_ADAPTER=false

# Day 2 synthetic traffic + alert dry-run (dev defaults)
DAY2_SYNTHETIC_BASE_URL=http://localhost:5000
DAY2_SYNTHETIC_ITERATIONS=40
DAY2_ALERT_BASE_URL=http://localhost:5000

# Prometheus scrapes GET /metrics (text exposition; same signals as /health/ops)

# Sentry error tracking (backend). Leave empty to disable (no-op).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Day 5 load ramp (read-only paths by default)
DAY5_BASE_URL=http://localhost:5000
DAY5_START_CONCURRENCY=2
DAY5_MAX_CONCURRENCY=24
DAY5_CONCURRENCY_STEP=2
DAY5_PHASE_DURATION_MS=15000
# DAY5_PATHS=/health,/health/ready,/metrics
DAY5_API_START=1
DAY5_API_MAX=8
DAY5_API_STEP=1
DAY5_API_PHASE_MS=12000
DAY5_API_GAP_MS=200

# Day 3 sequential JWT benchmark (append to DAY_PROGRESS.md)
# BENCH_BASE_URL=http://localhost:5000
DAY3_BENCH_REQUESTS=12
DAY3_REQUEST_DELAY_MS=350
DAY3_MAX_RETRIES_ON_429=3
# Pause between endpoints — inbox/grades share WRITE_RATE_LIMIT (default 120/min)
DAY3_INTER_ENDPOINT_PAUSE_MS=12000

# Upload/object storage (required for 2500+ concurrent users)
STORAGE_PROVIDER=cloudinary
FORCE_OBJECT_STORAGE=true
PREVIEW_STORAGE=cloudinary
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me
# FILE_STREAM_RATE_LIMIT=120
# FILE_DOWNLOAD_RATE_LIMIT=60
# Shared export dirs when running multiple API replicas (EFS/NFS mount path)
# JOB_EXPORTS_DIR=/mnt/lms-exports/job-exports
# INSTITUTION_EXPORTS_DIR=/mnt/lms-exports/institution
REQUIRE_MANAGED_MONGO=true

# Public landing "Contact" form → email (default recipient patelvivek9111@gmail.com)
# Use a Gmail App Password for CONTACT_SMTP_PASS (Google Account → Security → App passwords).
# If CONTACT_SMTP_* is unset, inquiries fall back to admin SystemSettings SMTP.
CONTACT_INQUIRY_RECIPIENT=patelvivek9111@gmail.com
CONTACT_SMTP_HOST=smtp.gmail.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_USER=patelvivek9111@gmail.com
CONTACT_SMTP_PASS=
CONTACT_SMTP_FROM=patelvivek9111@gmail.com
# Optional: stricter cap on submissions per IP (defaults: 15 min window, 8 requests)
# CONTACT_INQUIRY_WINDOW_MS=900000
# CONTACT_INQUIRY_MAX=8

# Frontend origin (production)
FRONTEND_URL=https://your-frontend-domain.com

# Multi-tenant (Canvas-style Account) — Phase 1
# DEFAULT_ROOT_ACCOUNT_CODE=DEFAULT
# DEFAULT_ROOT_ACCOUNT_NAME=Default Institution
# DEFAULT_TENANT_HOST=localhost
# TENANT_EXTRA_HOSTS=127.0.0.1,lms.localhost
# One-time migration: claim users with no rootAccountId into the login tenant.
# Default true. Set false after backfillRootAccountId (and related) have run.
ALLOW_LEGACY_USER_CLAIM=true

# SSO / custom domains / ACME (deferred backlog completed)
# API_PUBLIC_URL=https://your-backend-domain.com
# ACME_ENABLED=true
# ACME_EMAIL=ops@your-domain.com
# ACME_STAGING=true
# ACME_ACCOUNT_KEY_PATH=./uploads/tls-certs/acme-account.pem
# TLS_PROVISION_WEBHOOK_URL=
# TLS_PROVISION_WEBHOOK_SECRET=
# DOMAIN_VERIFY_FORCE=true
# SAML_ALLOW_UNSIGNED=true

# Frontend build-time API target (set in Vercel project env vars)
# Example: https://your-backend-domain.com
# Leave empty on Vercel to use same-origin /api (see vercel.json rewrites to Render).
# Never use template hosts like placeholder.onrender.com — they break CORS and are ignored in code.
VITE_API_URL=
# Public browser origin for course QR deep links (join-course). Defaults to window.location.origin when unset.
# VITE_APP_PUBLIC_URL=https://your-frontend-domain.com
# Optional: when VITE_API_URL is empty in production, QuizWave sockets use this origin (defaults to vedantalms-backend.onrender.com in code).
# VITE_SOCKET_ORIGIN=https://your-backend-domain.com

# Zoho Meeting OAuth (Phase 2)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=http://localhost:5000/api/integrations/zoho-meeting/callback
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_SCOPE=ZohoMeeting.meeting.ALL
ZOHO_FRONTEND_REDIRECT_URL=http://localhost:3000/groups
