# Frontend build-time env (copy to .env.local for local dev)
# API target — leave empty on Vercel to use same-origin /api rewrites
VITE_API_URL=

# P0 cost controls — enable websocket + slow polling fallback
VITE_NOTIFICATION_WEBSOCKET_ENABLED=true
VITE_INBOX_WEBSOCKET_ENABLED=true
# Optional override for notification poll when WS disconnected (ms, min 30000)
# VITE_NOTIFICATION_POLL_MS=30000

# Planner UX (optional)
# VITE_PLANNER_UX_ENABLED=true
